# Optional — the demo runs WITHOUT any keys (the deterministic engines handle
# everything rule-shaped in the browser). Keys only enable the LLM fallback
# layer that interprets messy free-form input.

# Primary NLU brain (Anthropic, via the Vercel AI SDK)
ANTHROPIC_API_KEY=

# Fallback NLU brain (Google Gemini free tier)
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: override the Gemini model used first in the fallback chain
# ROSTAGENT_MODEL=gemini-2.5-flash
